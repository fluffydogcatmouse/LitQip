# litqip environment configuration
# Place this file at ~/.litqip/.env and fill in your values

# Provider selection: "openrouter" (default) or "deepseek"
PROVIDER=openrouter

# --- OpenRouter (default provider) ---
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-haiku

# --- DeepSeek (set PROVIDER=deepseek to use) ---
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_THINKING=true   # uncomment to enable thinking mode

LOG_LEVEL=INFO
